# ═══════════════════════════════════════════
# QA System — Docker Compose Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════

# ── LLM Provider (pick at least one) ──
# Get a free API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key
# Optional: OpenAI or Anthropic
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-your-anthropic-key

# ── Model Selection ──
PRIMARY_MODEL=deepseek/deepseek-chat
FALLBACK_MODEL=deepseek/deepseek-chat

# ── Embedding ──
# "local" = free, runs on CPU (default)
# "ollama" = free, needs Ollama running
# "openai" = paid, best quality
EMBEDDING_PROVIDER=local

# ── Security ──
JWT_SECRET=change-me-to-a-random-string
DB_PASSWORD=postgres

# ── Ports (optional) ──
WEB_PORT=3000
API_PORT=8000

# ── Debug ──
DEBUG=false
