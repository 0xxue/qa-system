{
  "name": "@nexus/ai-bot",
  "version": "1.0.0",
  "description": "3D AI Bot Engine — Embedded intelligent assistant with VRM avatar, voice, and tool system",
  "keywords": ["ai", "bot", "3d", "vrm", "react", "assistant", "voice", "tts", "stt"],
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react --external react-dom --external three --external @pixiv/three-vrm",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "three": { "optional": true },
    "@pixiv/three-vrm": { "optional": true }
  },
  "dependencies": {
    "zustand": "^5.0.0",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
