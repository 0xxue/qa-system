# ══════════════════════════════════════
# AI QA System - Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════

# App
APP_ENV=development
DEBUG=true

# ── Database (PostgreSQL + pgvector) ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_qa

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# ── JWT Auth ──
JWT_SECRET=change-this-to-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM Providers (pick at least one) ──
PRIMARY_MODEL=deepseek/deepseek-chat
SECONDARY_MODEL=openai/gpt-4o
FALLBACK_MODEL=ollama/qwen2.5

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Budget control (USD per month)
MAX_BUDGET_MONTHLY=100.0

# ── Ollama (local models, free) ──
OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding ──
# Options: local (free, default) | ollama | openai | openai_compatible
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# Only needed for openai/openai_compatible:
# EMBEDDING_API_BASE=
# EMBEDDING_API_KEY=

# ── RAG ──
RAG_WORKING_DIR=./data/rag

# ── File Storage ──
FILE_STORAGE=local
UPLOAD_DIR=./data/uploads

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── CORS ──
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Monitoring ──
ENABLE_METRICS=true
LOG_LEVEL=INFO
LOG_FORMAT=console

# ── AI Bot (optional module) ──
ENABLE_AI_BOT=false
BOT_WEBSOCKET_PATH=/ws/bot
